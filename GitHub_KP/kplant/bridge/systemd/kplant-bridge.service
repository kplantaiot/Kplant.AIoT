[Unit]
Description=Kplant MQTT Bridge (HiveMQ -> Supabase)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=kittypau
WorkingDirectory=/home/kittypau/kplant-bridge
EnvironmentFile=/home/kittypau/kplant-bridge/.env
ExecStart=/usr/bin/node /home/kittypau/kplant-bridge/src/index.js
Restart=always
RestartSec=3
TimeoutStopSec=10
KillSignal=SIGINT

# Basic hardening
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
